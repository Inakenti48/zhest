








<!doctype html>
<html lang="ru">
    <head>
        <title>Satu.kz - маркетплейс</title>
        <meta charset='utf-8'>
        <meta name='viewport' content='width=device-width, initial-scale=1.0, user-scalable=no'>
        <style>
            * {
                margin: 0;
                padding: 0;
            }
            body {
                display: block;
                font-family: system-ui, -apple-system, Segoe UI, Roboto,
                    Ubuntu, Cantarell, Noto Sans, sans-serif;
                font-size: 0.875rem;
                line-height: 1.429em;
                font-weight: 400;
                margin: 0;
                color: #01011B;
                height: 100vh;
            }
            .container {
                position: relative;
                height: 100%;
            }
            .mainContent {
                display: flex;
                flex-direction: column;
                flex-wrap: nowrap;
                justify-content: center;
                align-items: center;
                height: 100%;
                text-align: center;
            }
            .logo {
                position: absolute;
                left: 50%;
                top: 32px;
                transform: translateX(-50%);
                fill: #01011B;
            }
            .imageWrapper {
                margin-bottom: 24px;
            }
            .title {
                font-size: 20px;
                font-weight: bold;
                margin-bottom: 16px;
            }
            .text {
                margin-bottom: 24px;
                margin-right: 25%;
                margin-left: 25%;
            }
            .button {
                display: inline-block;
                vertical-align: middle;
                box-sizing: border-box;
                padding: 10px 50px;
                border: 1px solid #7B04DF;
                border-radius: 8px;
                background: #7B04DF;
                font: inherit;
                font-weight: bold;
                line-height: 1.4;
                color: white;
                appearance: none;
                text-decoration: none;
                user-select: none;
                outline: none;
                cursor: pointer;
                transition-property: color, background-color, border-color;
                max-width: 100%;
                transition: 150ms ease-in-out;
            }
            .button:hover {
                background: #6200d1;
                border-color: #6200d1;
                text-decoration: none;
            }

            @media (prefers-color-scheme: dark) {
                body {
                    color: #fff;
                    background: #353639;
                }
                .button {
                    background: #bc88fd;
                    border-color: #bc88fd;
                    color: #272a2b;
                }
                .logo {
                    color: #fff;
                }
            }


        </style>
    </head>

    <body class='body'>
        <div class='container'>
            <div class='logo'>
                <img
                    src="/cloud-cgi/static/uaprom-static/image/portal/KZ/logo-hc81f57538b0cd3cc52aa67f40edd0b300.svg"
                    alt="Satu.kz"
                >
            </div>
            <div class='mainContent'>
                <div class='imageWrapper'>
                    
    <img src="/cloud-cgi/static/uaprom-static/image/portal/mascots/not-found-hc13122dae1e434a61607ee77c7ff59caa.svg">

                </div>
                <h1 class='title'>
                    
